# Copy this file to .env and fill in your values
# cp .env.example .env

# ── MinIO ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── MLflow ─────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
# MLflow pakai kredensial MinIO di atas (AWS_* vars)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── ZenML ──────────────────────────────────────────────
ZENML_USER=admin
ZENML_PASSWORD=admin
ZENML_MYSQL_ROOT_PASSWORD=zenml
ZENML_MYSQL_PASSWORD=zenml

# ── Attend.AI — export enrollment data ─────────────────
ATTEND_DB_PATH=../attend/server/attend.db
ATTEND_PHOTOS_DIR=../attend/server/data/persons

# ── Attend integration AI runtime ───────────────────────
AI_HOST=0.0.0.0
AI_PORT=5679
AI_JPEG_QUALITY=75
AI_INFERENCE_EVERY_N_FRAMES=3
AI_FACE_CAPTURE_INTERVAL_SECONDS=5
