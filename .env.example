# Copy this file to .env and fill in your values
# cp .env.example .env

# MLflow Tracking Server
MLFLOW_TRACKING_URI=http://localhost:5000

# MinIO (artifact storage untuk MLflow dan DVC remote)
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=your_minio_access_key
AWS_SECRET_ACCESS_KEY=your_minio_secret_key

# Attend.AI — path ke SQLite DB untuk export enrollment data
# Dipakai oleh data/sources/export_attend.py
ATTEND_DB_PATH=../attend/server/attend.db
ATTEND_PHOTOS_DIR=../attend/server/data/persons
