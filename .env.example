# Copy this file to .env and fill in your values
# cp .env.example .env

# ── MinIO ──────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── MLflow ─────────────────────────────────────────────
# Use Docker service hostnames when running inside containers,
# or http://localhost:5000 / http://localhost:9000 for local dev.
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
# MLflow pakai kredensial MinIO di atas (AWS_* vars)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# MLflow basic auth — initial admin credentials (only applied on first startup)
MLFLOW_ADMIN_USERNAME=admin
MLFLOW_ADMIN_PASSWORD=admin
# MLflow CSRF secret key — set a random string, keep consistent across restarts
MLFLOW_FLASK_SERVER_SECRET_KEY=changeme

# ── ZenML ──────────────────────────────────────────────
ZENML_USER=admin
ZENML_PASSWORD=admin
ZENML_MYSQL_ROOT_PASSWORD=zenml
ZENML_MYSQL_PASSWORD=zenml

# ── Attend.AI — export enrollment data ─────────────────
ATTEND_DB_PATH=../attend/server/attend.db
ATTEND_PHOTOS_DIR=../attend/server/data/persons

# ── Attend integration AI runtime ───────────────────────
AI_HOST=0.0.0.0
AI_PORT=5679
AI_JPEG_QUALITY=75
AI_INFERENCE_EVERY_N_FRAMES=3
AI_FACE_CAPTURE_INTERVAL_SECONDS=5
